# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==========================================
MONGODB_URI=mongodb://localhost:27017/plataforma_monetizacion
# Atlas (ejemplo; reemplazar con tu cluster/db, NO commitear credenciales reales)
# MONGODB_URI=mongodb+srv://<USER>:<PASSWORD>@<CLUSTER_HOST>/<DB_NAME>?retryWrites=true&w=majority
MONGODB_TEST_URI=mongodb://localhost:27017/plataforma_monetizacion_test

# ==========================================
# CONFIGURACIÓN JWT
# ==========================================
JWT_SECRET=tu_jwt_secret_muy_seguro_cambialo_en_produccion
JWT_REFRESH_SECRET=tu_refresh_secret_muy_seguro_cambialo_en_produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# CONFIGURACIÓN DE STRIPE
# ==========================================
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta_de_stripe
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_de_stripe
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret_de_stripe
STRIPE_CURRENCY=usd

# ==========================================
# CONFIGURACIÓN DE EMAIL
# ==========================================
# Opciones: gmail, outlook, sendgrid, mailgun, smtp
EMAIL_PROVIDER=gmail
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_password_de_aplicacion
EMAIL_FROM_NAME=Plataforma Monetización
EMAIL_FROM_ADDRESS=noreply@plataforma-monetizacion.com

# ==========================================
# CONFIGURACIÓN DEL SERVIDOR
# ==========================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
VITE_API_URL=
NEXT_PUBLIC_API_URL=https://tu-backend.com/api

# ==========================================
# CONFIGURACIÓN DE ARCHIVOS
# ==========================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_DOCUMENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
MAX_FILES_PER_UPLOAD=5

# ==========================================
# CONFIGURACIÓN DE APIS EXTERNAS
# ==========================================
# Para verificación de canales de Telegram
TELEGRAM_BOT_TOKEN=tu_bot_token_de_telegram

# Para verificación de canales de Discord
DISCORD_BOT_TOKEN=tu_bot_token_de_discord
DISCORD_CLIENT_ID=tu_client_id_de_discord
DISCORD_CLIENT_SECRET=tu_client_secret_de_discord

# Para verificación de Instagram
INSTAGRAM_ACCESS_TOKEN=tu_access_token_de_instagram
INSTAGRAM_CLIENT_ID=tu_client_id_de_instagram
INSTAGRAM_CLIENT_SECRET=tu_client_secret_de_instagram

# Para WhatsApp Business
WHATSAPP_BUSINESS_API_TOKEN=tu_token_whatsapp_business
META_APP_ID=tu_app_id_meta
META_APP_SECRET=tu_app_secret_meta

# ==========================================
# CONFIGURACIÓN DE SEGURIDAD
# ==========================================
ENCRYPTION_KEY=tu_clave_de_encriptacion_de_32_caracteres
SESSION_SECRET=tu_session_secret_muy_seguro
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ==========================================
# CONFIGURACIÓN DE RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_AUTH_MAX=50
RATE_LIMIT_UPLOAD_MAX=10

# ==========================================
# COMISIÓN DE LA PLATAFORMA
# ==========================================
PLATFORM_COMMISSION_RATE=0.10
