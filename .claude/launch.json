{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (nodemon)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5000
    },
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "frontend:dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Full Stack (concurrently)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:full"],
      "port": 5000
    }
  ]
}
