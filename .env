# Configuración del servidor
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://plataforma.com
NEXT_PUBLIC_API_URL=

# Base de datos MongoDB
MONGODB_URI=mongodb://localhost:27017/monetizacion
DB_SSL=false

# Base de datos PostgreSQL (opcional)
POSTGRES_URI=postgresql://localhost:5432/monetizacion

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=tu-jwt-secret-muy-seguro-cambialo-en-produccion
JWT_REFRESH_SECRET=tu-refresh-secret-muy-seguro-cambialo-en-produccion
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# APIs de Plataformas (configurar con tokens reales)
TELEGRAM_BOT_TOKEN=
WHATSAPP_TOKEN=
META_ACCESS_TOKEN=
DISCORD_BOT_TOKEN=

# Pagos (configurar con credenciales reales)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Email (configurar con credenciales reales)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Configuración de comisiones
COMMISSION_PERCENTAGE=10
MINIMUM_COMMISSION=1

# Configuración de archivos
MAX_FILE_SIZE=5MB
UPLOAD_PATH=./uploads

# Rate limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
